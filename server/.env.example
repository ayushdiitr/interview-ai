PORT=3847
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_API_KEY=change-me-admin-key
# Trial length for new registrations (days)
TRIAL_DAYS=14

# Optional: force-disable TLS for pg (local Docker only)
# PGSSLMODE=disable

# Optional: comma-separated browser origins for CORS (e.g. https://admin.example.com)
CORS_ORIGINS=*

# Optional: absolute path to built React admin (default: ../admin-web/dist)
# ADMIN_STATIC_DIR=

